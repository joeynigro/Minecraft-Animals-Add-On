{
    "format_version": "1.16.0",
    "minecraft:entity": {
        "description": {
            "identifier": "animals:skunk",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false
        },
        "component_groups": {
            "animals:baby": {
                "minecraft:is_baby": {},
                "minecraft:scale": {
                    "value": 0.7
                },
                "minecraft:ageable": {
                    "duration": 1200,
                    "feed_items": [
                        "minecraft:sweet_berries",
                        "minecraft:apple"
                    ],
                    "grow_up": {
                        "event": "minecraft:ageable_grow_up",
                        "target": "self"
                    }
                }
            },
            "animals:adult": {
                "minecraft:attack": {
                    "damage": 0
                },
                "minecraft:area_attack": {
                    "damage": 0,
                    "radius": 3.0,
                    "effect_name": "poison",
                    "effect_duration": 120,
                    "effect_amplifier": 0,
                    "cooldown_time": 8.0
                },
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 3,
                    "must_see": true,
                    "entity_types": [{
                            "filters": {
                                "test": "is_family",
                                "subject": "other",
                                "value": "player"
                            },
                            "max_dist": 4
                        }
                    ]
                },
                "minecraft:behavior.melee_attack": {
                    "priority": 4,
                    "track_target": true,
                    "reach_multiplier": 1.5
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": [
                    "skunk",
                    "small_animal",
                    "animal"
                ]
            },
            "minecraft:collision_box": {
                "width": 0.8,
                "height": 0.9
            },
            "minecraft:health": {
                "value": 12,
                "max": 12
            },
            "minecraft:movement": {
                "value": 0.2
            },
            "minecraft:movement.basic": {},
            "minecraft:jump.static": {},
            "minecraft:navigation.walk": {
                "can_path_over_water": false,
                "can_pass_doors": false,
                "can_open_doors": false,
                "avoid_water": true
            },
            "minecraft:behavior.float": {
                "priority": 0
            },
            "minecraft:behavior.panic": {
                "priority": 1,
                "speed_multiplier": 1.3
            },
            "minecraft:behavior.tempt": {
                "priority": 2,
                "speed_multiplier": 1.1,
                "items": [
                    "minecraft:sweet_berries",
                    "minecraft:apple"
                ]
            },
            "minecraft:behavior.random_stroll": {
                "priority": 5,
                "speed_multiplier": 1.0
            },
            "minecraft:behavior.look_at_player": {
                "priority": 6,
                "look_distance": 6.0,
                "probability": 0.02
            },
            "minecraft:behavior.random_look_around": {
                "priority": 7
            },
            "minecraft:follow_range": {
                "value": 12
            },
            "minecraft:nameable": {},
            "minecraft:despawn": {
                "despawn_from_distance": {}
            },
            "minecraft:experience_reward": {
                "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
            }
        },
        "events": {
            "minecraft:entity_spawned": {
                "randomize": [{
                        "weight": 80,
                        "add": {
                            "component_groups": [
                                "animals:adult"
                            ]
                        }
                    }, {
                        "weight": 20,
                        "add": {
                            "component_groups": [
                                "animals:baby"
                            ]
                        }
                    }
                ]
            },
            "minecraft:ageable_grow_up": {
                "remove": {
                    "component_groups": [
                        "animals:baby"
                    ]
                },
                "add": {
                    "component_groups": [
                        "animals:adult"
                    ]
                }
            },
            "animals:on_breed": {
                "add": {
                    "component_groups": [
                        "animals:baby"
                    ]
                }
            }
        }
    }
}
