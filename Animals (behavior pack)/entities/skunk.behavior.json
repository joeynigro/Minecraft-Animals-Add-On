{
    "format_version": "1.16.0",
    "minecraft:entity": {
        "description": {
            "identifier": "animals:skunk",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false
        },
        "component_groups": {
            "minecraft:baby": {
                "minecraft:is_baby": {},
                "minecraft:scale": {
                    "value": 0.55
                },
                "minecraft:ageable": {
                    "duration": 1200,
                    "feed_items": [
                        "minecraft:sweet_berries",
                        "minecraft:apple"
                    ],
                    "grow_up": {
                        "event": "minecraft:ageable_grow_up",
                        "target": "self"
                    }
                }
            },
            "minecraft:adult": {
                "minecraft:attack": {
                    "damage": 0
                },
                "minecraft:behavior.nearest_attackable_target": {
                    "priority": 3,
                    "must_see": true,
                    "within_radius": 4.0,
                    "entity_types": [
                        {
                            "filters": {
                                "test": "is_family",
                                "subject": "other",
                                "value": "player"
                            },
                            "max_dist": 4
                        }
                    ]
                },
                "minecraft:behavior.delayed_attack": {
                    "priority": 4,
                    "attack_once": false,
                    "track_target": true,
                    "require_complete_path": false,
                    "random_stop_interval": 0,
                    "reach_multiplier": 1.0,
                    "speed_multiplier": 1.0,
                    "attack_duration": 0.75,
                    "hit_delay_pct": 0.5
                },
                "minecraft:entity_sensor": {
                    "sensor_range": 4.0,
                    "relative_range": false,
                    "minimum_count": 1,
                    "event_filters": {
                        "test": "is_family",
                        "subject": "other",
                        "value": "player"
                    },
                    "event": "animals:start_warning"
                }
            },
            "animals:warning": {
                "minecraft:timer": {
                    "looping": false,
                    "time": 1.0,
                    "time_down_event": {
                        "event": "animals:start_spraying",
                        "target": "self"
                    }
                }
            },
            "animals:spraying": {
                "minecraft:area_attack": {
                    "damage_range": 2.5,
                    "damage_per_tick": 0,
                    "cause": "contact",
                    "entity_filter": {
                        "test": "is_family",
                        "subject": "other",
                        "value": "player"
                    }
                },
                "minecraft:mob_effect": {
                    "effect_range": 2.5,
                    "mob_effect": "poison",
                    "effect_time": 60,
                    "entity_filter": {
                        "test": "is_family",
                        "subject": "other",
                        "value": "player"
                    }
                },
                "minecraft:timer": {
                    "looping": false,
                    "time": 1.5,
                    "time_down_event": {
                        "event": "animals:stop_spraying",
                        "target": "self"
                    }
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": [
                    "skunk",
                    "small_animal",
                    "animal"
                ]
            },
            "minecraft:breathable": {
                "total_supply": 15,
                "suffocate_time": 0
            },
            "minecraft:nameable": {},
            "minecraft:physics": {},
            "minecraft:collision_box": {
                "width": 0.8,
                "height": 0.9
            },
            "minecraft:health": {
                "value": 12,
                "max": 12
            },
            "minecraft:movement": {
                "value": 0.2
            },
            "minecraft:movement.basic": {},
            "minecraft:jump.static": {},
            "minecraft:navigation.walk": {
                "can_path_over_water": false,
                "can_pass_doors": false,
                "can_open_doors": false,
                "avoid_water": true
            },
            "minecraft:behavior.float": {
                "priority": 0
            },
            "minecraft:behavior.panic": {
                "priority": 1,
                "speed_multiplier": 1.3
            },
            "minecraft:behavior.tempt": {
                "priority": 2,
                "speed_multiplier": 1.1,
                "items": [
                    "minecraft:sweet_berries",
                    "minecraft:apple"
                ]
            },
            "minecraft:behavior.random_stroll": {
                "priority": 5,
                "speed_multiplier": 1.0
            },
            "minecraft:behavior.look_at_player": {
                "priority": 6,
                "look_distance": 6.0,
                "probability": 0.02
            },
            "minecraft:behavior.random_look_around": {
                "priority": 7
            },
            "minecraft:follow_range": {
                "value": 12
            },
            "minecraft:despawn": {
                "despawn_from_distance": {}
            },
            "minecraft:experience_reward": {
                "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
            },
            "minecraft:pushable": {
                "is_pushable": false,
                "is_pushable_by_piston": false
            },
            "minecraft:conditional_bandwidth_optimization": {}
        },
        "events": {
            "minecraft:entity_spawned": {
                "randomize": [
                    {
                        "weight": 80,
                        "add": {
                            "component_groups": [
                                "minecraft:adult"
                            ]
                        }
                    },
                    {
                        "weight": 20,
                        "add": {
                            "component_groups": [
                                "minecraft:baby"
                            ]
                        }
                    }
                ]
            },
            "minecraft:ageable_grow_up": {
                "remove": {
                    "component_groups": [
                        "minecraft:baby"
                    ]
                },
                "add": {
                    "component_groups": [
                        "minecraft:adult"
                    ]
                }
            },
            "animals:start_warning": {
                "add": {
                    "component_groups": [
                        "animals:warning"
                    ]
                }
            },
            "animals:start_spraying": {
                "remove": {
                    "component_groups": [
                        "animals:warning"
                    ]
                },
                "add": {
                    "component_groups": [
                        "animals:spraying"
                    ]
                }
            },
            "animals:stop_spraying": {
                "remove": {
                    "component_groups": [
                        "animals:spraying",
                        "animals:warning"
                    ]
                }
            }
        }
    }
}
