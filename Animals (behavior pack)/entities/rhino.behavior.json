{
    "format_version": "1.16.0",
    "minecraft:entity": {
        "description": {
            "identifier": "animals:rhino",
            "is_spawnable": true,
            "is_summonable": true,
            "is_experimental": false
        },
        "component_groups": {
            "animals:baby": {
                "minecraft:is_baby": {},
                "minecraft:scale": {
                    "value": 0.6
                },
                "minecraft:ageable": {
                    "duration": 1200,
                    "feed_items": [
                        "minecraft:wheat",
                        "minecraft:apple"
                    ],
                    "grow_up": {
                        "event": "minecraft:ageable_grow_up",
                        "target": "self"
                    }
                }
            }
        },
        "components": {
            "minecraft:type_family": {
                "family": [
                    "rhino",
                    "large_animal",
                    "animal"
                ]
            },
            "minecraft:collision_box": {
                "width": 1.6,
                "height": 1.8
            },
            "minecraft:health": {
                "value": 40,
                "max": 40
            },
            "minecraft:movement": {
                "value": 0.18
            },
            "minecraft:jump.static": {},
            "minecraft:navigation.walk": {
                "can_path_over_water": false,
                "can_pass_doors": false,
                "can_open_doors": false,
                "avoid_water": true
            },
            "minecraft:movement.basic": {},
            "minecraft:behavior.random_stroll": {
                "priority": 6,
                "speed_multiplier": 1.0
            },
            "minecraft:behavior.look_at_player": {
                "priority": 7,
                "look_distance": 8.0,
                "probability": 0.02
            },
            "minecraft:behavior.random_look_around": {
                "priority": 8
            },
            "minecraft:behavior.float": {
                "priority": 1
            },
            "minecraft:behavior.panic": {
                "priority": 2,
                "speed_multiplier": 1.25
            },
            "minecraft:behavior.tempt": {
                "priority": 3,
                "speed_multiplier": 1.1,
                "items": [
                    "minecraft:wheat",
                    "minecraft:apple"
                ]
            },
            "minecraft:attack": {
                "damage": 8
            },
            "minecraft:behavior.melee_attack": {
                "priority": 4,
                "speed_multiplier": 1.2,
                "track_target": true
            },
            "minecraft:behavior.nearest_attackable_target": {
                "priority": 5,
                "must_see": true,
                "entity_types": [{
                        "filters": {
                            "test": "is_family",
                            "subject": "other",
                            "value": "player"
                        },
                        "max_dist": 8
                    }
                ]
            },
            "minecraft:follow_range": {
                "value": 16
            },
            "minecraft:nameable": {},
            "minecraft:despawn": {
                "despawn_from_distance": {}
            },
            "minecraft:experience_reward": {
                "on_death": "query.last_hit_by_player ? Math.Random(1,3) : 0"
            }
        },
        "events": {
            "minecraft:entity_spawned": {
                "randomize": [{
                        "weight": 85,
                        "add": {
                            "component_groups": [
                                "minecraft:adult"
                            ]
                        }
                    }, {
                        "weight": 15,
                        "add": {
                            "component_groups": [
                                "minecraft:baby"
                            ]
                        }
                    }
                ]
            },
            "minecraft:ageable_grow_up": {
                "remove": {
                    "component_groups": [
                        "minecraft:baby"
                    ]
                },
                "add": {
                    "component_groups": [
                        "minecraft:adult"
                    ]
                }
            }
        }
    }
}
