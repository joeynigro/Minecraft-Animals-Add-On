{
    "format_version": "1.8.0",
    "minecraft:spawn_rules": {
        "description": {
            "identifier": "animals:squirrel",
            "population_control": "animal"
        },
        "conditions": [{
                "minecraft:spawns_on_surface": {},
                "minecraft:spawns_on_block_filter": [{
                        "name": "minecraft:grass_block"
                    }, {
                        "name": "minecraft:dirt"
                    }, {
                        "name": "minecraft:podzol"
                    }
                ],
                "minecraft:spawns_on_block_prevented_filter": [
                    "minecraft:water",
                    "minecraft:lava"
                ],
                "minecraft:brightness_filter": {
                    "min": 7,
                    "max": 15,
                    "adjust_for_weather": false
                },
                "minecraft:height_filter": {
                    "min": 60,
                    "max": 130
                },
                "minecraft:weight": {
                    "default": 28
                },
                "minecraft:herd": {
                    "min_size": 1,
                    "max_size": 3
                },
                "minecraft:density_limit": {
                    "surface": 6,
                    "underground": 0
                },
                "minecraft:biome_filter": [{
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "forest"
                    }, {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "birch_forest"
                    }, {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "taiga"
                    }, {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "plains"
                    }
                ]
            }
        ]
    }
}
