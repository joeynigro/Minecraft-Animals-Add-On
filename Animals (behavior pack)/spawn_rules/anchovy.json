{
    "format_version": "1.8.0",
    "minecraft:spawn_rules": {
        "description": {
            "identifier": "animals:anchovy",
            "population_control": "water_ambient"
        },
        "conditions": [{
                "minecraft:spawns_on_surface": {},
                "minecraft:spawns_underwater": {},
                "minecraft:brightness_filter": {
                    "min": 0,
                    "max": 15,
                    "adjust_for_weather": false
                },
                "minecraft:height_filter": {
                    "min": 60,
                    "max": 100
                },
                "minecraft:weight": {
                    "default": 80
                },
                "minecraft:herd": {
                    "min_size": 3,
                    "max_size": 8
                },
                "minecraft:biome_filter": [{
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "ocean"
                    }, {
                        "test": "has_biome_tag",
                        "operator": "==",
                        "value": "river"
                    }
                ]
            }
        ]
    }
}
