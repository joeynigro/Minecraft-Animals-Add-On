{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.alligator.attack": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "bite": "query.is_attacking"
            }
          ]
        },

        "bite": {
          "animations": [
            "bite"
          ],
          "transitions": [
            {
              "default": "query.all_animations_finished"
            }
          ]
        }
      }
    }
  }
}
