{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.alligator.move": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "swim": "query.is_in_water"
            },
            {
              "walk": "query.modified_move_speed > 0.01"
            }
          ]
        },

        "walk": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "swim": "query.is_in_water"
            },
            {
              "idle": "query.modified_move_speed <= 0.01"
            }
          ]
        },

        "swim": {
          "animations": [
            "swim"
          ],
          "transitions": [
            {
              "walk": "!query.is_in_water && query.modified_move_speed > 0.01"
            },
            {
              "idle": "!query.is_in_water && query.modified_move_speed <= 0.01"
            }
          ]
        }
      }
    },

    "controller.animation.alligator.attack": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "bite": "query.is_angry"
            }
          ]
        },

        "bite": {
          "animations": [
            "bite"
          ],
          "transitions": [
            {
              "default": "query.all_animations_finished"
            }
          ]
        }
      }
    }
  }
}