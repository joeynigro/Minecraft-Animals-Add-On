{
  "format_version": "1.10.0",
  "animation_controllers": {
    "controller.animation.crab.move": {
      "initial_state": "idle",
      "states": {
        "idle": {
          "animations": [
            "idle"
          ],
          "transitions": [
            {
              "walk": "query.modified_move_speed > 0.01"
            }
          ]
        },
        "walk": {
          "animations": [
            "walk"
          ],
          "transitions": [
            {
              "idle": "query.modified_move_speed <= 0.01"
            }
          ]
        }
      }
    },
    "controller.animation.crab.attack": {
      "initial_state": "default",
      "states": {
        "default": {
          "transitions": [
            {
              "snap": "variable.attack_time > 0.0"
            }
          ]
        },
        "snap": {
          "animations": [
            "snap"
          ],
          "transitions": [
            {
              "default": "query.all_animations_finished"
            }
          ]
        }
      }
    }
  }
}
