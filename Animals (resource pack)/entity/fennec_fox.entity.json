      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/fennec_fox"
      },
      "geometry": {
        "default": "geometry.fennec_fox"
      },
      "animations": {
        "idle": "animation.fennec_fox.idle",
        "walk": "animation.quadruped.walk",
        "look_at_target": "animation.common.look_at_target"
