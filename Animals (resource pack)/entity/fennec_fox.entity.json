          {
            "idle": "1.0 - math.min(query.modified_move_speed, 1.0)"
          }
        ]
      },
      "render_controllers": [
        "controller.render.fennec_fox"
      ],
      "spawn_egg": {
        "texture": "fennec_fox_spawn_egg"
      },
      "sound_effects": {
        "ambient": "fennec_fox.idle",
        "hurt": "fennec_fox.hurt",
        "death": "fennec_fox.death",
        "eat": "fennec_fox.eat",
        "attack": "fennec_fox.bite",
        "screech": "fennec_fox.screech"
      }
    }
  }
}
