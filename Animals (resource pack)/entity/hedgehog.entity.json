{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "animals:hedgehog",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/hedgehog"
      },
      "geometry": {
        "default": "geometry.hedgehog"
      },
      "animations": {
        "walk": "animation.hedgehog.walk",
        "roll_up": "animation.hedgehog.roll_up",
        "unroll": "animation.hedgehog.unroll",
        "rolled_idle": "animation.hedgehog.rolled_idle",
        "roll_state": "controller.animation.hedgehog.roll_state"
      },
      "scripts": {
        "initialize": [
          "variable.use_rolled_up_model = 0;"
        ],
        "animate": [
          "roll_state",
          {
            "walk": "query.modified_move_speed > 0.01 && variable.use_rolled_up_model == 0"
          }
        ]
      },
      "render_controllers": [
        "controller.render.hedgehog"
      ],
      "spawn_egg": {
        "texture": "hedgehog_spawn_egg"
      },
      "sound_effects": {
        "ambient": "hedgehog.idle",
        "hurt": "hedgehog.hurt",
        "death": "hedgehog.death"
      }
    }
  }
}
