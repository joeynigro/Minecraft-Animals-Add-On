{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "animals:platypus",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/platypus"
      },
      "geometry": {
        "default": "geometry.platypus"
      },
      "animations": {
        "idle": "animation.platypus.idle",
        "walk": "animation.platypus.walk",
        "swim": "animation.platypus.swim",
        "look_at_target": "animation.common.look_at_target"
      },
      "scripts": {
        "animate": [
          "look_at_target",
          {
            "swim": "query.is_in_water"
          },
          {
            "walk": "!query.is_in_water && query.ground_speed > 0.01"
          },
          {
            "idle": "!query.is_in_water && query.ground_speed <= 0.01"
          }
        ]
      },
      "render_controllers": [
        "controller.render.platypus"
      ],
      "spawn_egg": {
        "texture": "platypus_spawn_egg"
      }
    }
  }
}