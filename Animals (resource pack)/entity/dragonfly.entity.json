{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "animals:dragonfly",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/dragonfly"
      },
      "geometry": {
        "default": "geometry.dragonfly"
      },
      "animations": {
        "idle": "animation.dragonfly.idle",
        "fly": "animation.dragonfly.fly",
        "land": "animation.dragonfly.land"
      },
      "scripts": {
        "animate": [
          {
            "land": "query.is_on_ground"
          },
          {
            "fly": "!query.is_on_ground && query.modified_move_speed > 0.02"
          },
          {
            "idle": "!query.is_on_ground && query.modified_move_speed <= 0.02"
          }
        ]
      },
      "render_controllers": [
        "controller.render.dragonfly"
      ],
      "spawn_egg": {
        "texture": "dragonfly_spawn_egg"
      },
      "sound_effects": {
        "hurt": "dragonfly.hurt",
        "death": "dragonfly.death"
      }
    }
  }
}
