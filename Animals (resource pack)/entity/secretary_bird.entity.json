{
	"format_version": "1.10.0",
	"minecraft:client_entity": {
		"description": {
			"identifier": "animals:secretary_bird",
			"materials": {
				"default": "entity_alphatest"
			},
			"textures": {
				"default": "textures/entity/secretary_bird"
			},
			"geometry": {
				"default": "geometry.secretary_bird"
			},
            "animations": {
                "idle": "animation.secretary_bird.idle",
                "walk": "animation.secretary_bird.walk",
                "stomp": "animation.secretary_bird.stomp",
                "look_at_target": "animation.common.look_at_target"
            },
            "scripts": {
                "animate": [
                    "look_at_target", {
                        "walk": "query.modified_move_speed > 0.01"
                    }, {
                        "stomp": "variable.attack_time"
                    }, {
                        "idle": "query.modified_move_speed <= 0.01"
                    }
                ]
            },
			"render_controllers": ["controller.render.secretary_bird"],
			"spawn_egg": {
				"texture": "secretary_bird_spawn_egg"
			}
		}
	}
}
