{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "animals:squirrel",
            "materials": {
                "default": "entity_alphatest"
            },
            "textures": {
                "default": "textures/entity/squirrel"
            },
            "geometry": {
                "default": "geometry.squirrel"
            },
            "animations": {
                "idle": "animation.squirrel.idle",
                "walk": "animation.squirrel.walk",
                "jump": "animation.squirrel.jump",
                "look_at_target": "animation.common.look_at_target"
            },
            "scripts": {
                "animate": [
                    "look_at_target", {
                        "jump": "query.is_jumping"
                    }, {
                        "walk": "!query.is_jumping && query.ground_speed > 0.01"
                    }, {
                        "idle": "!query.is_jumping && query.ground_speed <= 0.01"
                    }
                ]
            },
            "render_controllers": ["controller.render.squirrel"],
            "spawn_egg": {
                "texture": "squirrel_spawn_egg"
            }
        }
    }
}
