{
  "format_version": "1.10.0",
  "minecraft:client_entity": {
    "description": {
      "identifier": "animals:shark",
      "materials": {
        "default": "entity_alphatest"
      },
      "textures": {
        "default": "textures/entity/shark"
      },
      "geometry": {
        "default": "geometry.shark"
      },
      "animations": {
        "flop": "animation.shark.flop",
        "swim": "animation.shark.swim",
        "bite": "animation.shark.bite"
      },
      "scripts": {
        "animate": [
          {
            "flop": "!query.is_in_water"
          },
          {
            "swim": "query.is_in_water && variable.attack_time <= 0.0"
          },
          {
            "bite": "query.is_in_water && variable.attack_time > 0.0"
          }
        ]
      },
      "render_controllers": [
        "controller.render.shark"
      ],
      "spawn_egg": {
        "texture": "shark_spawn_egg"
      },
      "sound_effects": {
        "ambient": "shark.idle",
        "hurt": "shark.hurt",
        "death": "shark.death"
      }
    }
  }
}
