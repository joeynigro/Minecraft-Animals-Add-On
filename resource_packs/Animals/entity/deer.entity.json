{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "animals:deer",
            "materials": {
                "default": "entity_alphatest"
            },
            "textures": {
                "default": "textures/entity/deer",
                "baby": "textures/entity/deer_baby"
            },
            "geometry": {
                "default": "geometry.deer",
                "baby": "geometry.deer.baby"
            },
            "animations": {
                "idle": "animation.deer.idle",
                "walk": "animation.quadruped.walk",
                "look_at_target": "animation.common.look_at_target"
            },
            "scripts": {
                "animate": [
                    "look_at_target", {
                        "walk": "query.modified_move_speed"
                    }, {
                        "idle": "(1.0 - math.min(query.modified_move_speed, 1.0)) : 0.0"
                    }
                ]
            },
            "render_controllers": ["controller.deer.default"],
            "spawn_egg": {
                "texture": "deer_spawn_egg"
            }
        }
    }
}