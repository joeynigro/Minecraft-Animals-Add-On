{
    "format_version": "1.10.0",
    "minecraft:client_entity": {
        "description": {
            "identifier": "animals:beaver",
            "materials": {
                "default": "entity_alphatest"
            },
            "textures": {
                "default": "textures/entity/beaver",
                "baby": "textures/entity/beaver_baby"
            },
            "geometry": {
                "default": "geometry.beaver",
                "baby": "geometry.beaver.baby"
            },
            "animations": {
                "idle": "animation.beaver.idle",
                "walk": "animation.quadruped.walk",
                "swim": "animation.quadruped.swim",
                "look_at_target": "animation.common.look_at_target"
            },
            "scripts": {
                "animate": [
                    "look_at_target", {
                        "swim": "query.is_in_water"
                    }, {
                        "walk": "!query.is_in_water * query.modified_move_speed"
                    }, {
                        "idle": "!query.is_in_water * (1.0 - math.min(query.modified_move_speed, 1.0))"
                    }
                ]
            },
            "render_controllers": ["controller.render.beaver"],
            "spawn_egg": {
                "texture": "beaver_spawn_egg"
            }
        }
    }
}